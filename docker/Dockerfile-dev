ARG IMAGE
FROM $IMAGE
RUN addgroup -S galaksion && adduser -S galaksion -G galaksion
WORKDIR /app
ARG \
    CONFIGURE_SITE \ 
	NPM_COMMAND \
	NEXT_PUBLIC_SITE_URL \
	NEXT_PUBLIC_API_URL \
	NEXT_PUBLIC_IMAGES_URL \
	NEXT_PUBLIC_RECAPTCHA_KEY \
	NEXT_PUBLIC_PUBLISHER_REGISTRATION_URL
ENV \
	NPM_COMMAND=${NPM_COMMAND} \
	NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL} \
	NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL} \
	NEXT_PUBLIC_IMAGES_URL=${NEXT_PUBLIC_IMAGES_URL} \ 
	NEXT_PUBLIC_RECAPTCHA_KEY=${NEXT_PUBLIC_RECAPTCHA_KEY} 
	NEXT_PUBLIC_PUBLISHER_REGISTRATION_URL=${NEXT_PUBLIC_PUBLISHER_REGISTRATION_URL}
COPY . .
RUN \
	mv /node_modules /app/ && \
	npm run configure-$CONFIGURE_SITE && \
	npm run build && \
	rm -f .env.development && \
	chown -R galaksion:galaksion /app
USER galaksion
ENTRYPOINT ["/bin/sh","-c"]
CMD ["npm run start"]